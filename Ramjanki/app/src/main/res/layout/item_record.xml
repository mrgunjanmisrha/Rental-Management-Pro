<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/Widget.Temple.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/recordTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Room 101"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
            <!-- Status Badge -->
            <TextView
                android:id="@+id/recordReservation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_badge_gold"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="Booked"
                android:visibility="gone"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold" />

            <!-- Status Badge -->
            <TextView
                android:id="@+id/recordStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="@drawable/bg_badge_gold"
                android:paddingHorizontal="12dp"
                android:layout_marginStart="5dp"
                android:paddingVertical="4dp"
                android:text="Paid"
                android:textColor="@color/white"
                android:textSize="8sp"
                android:textStyle="bold" />

        </LinearLayout>

        <TextView
            android:id="@+id/recordSubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Rahul Kumar"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:alpha="0.3"
            android:background="@color/line_gold_soft" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_wallet"
                app:tint="@color/secondary_gold" />

            <TextView
                android:id="@+id/recordDetail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Due: ₹500"
                android:textColor="@color/primary_maroon"
                android:textSize="8sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/editRecordButton"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:paddingHorizontal="8dp"
                android:text="@string/edit"
                android:textColor="@color/primary_maroon" />
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
